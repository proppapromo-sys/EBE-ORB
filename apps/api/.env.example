PORT=8080

# ── Persistence ──────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── ORB Multi-Model Council ──────────────────────────────────
# GPT-Executive / GPT-Operations / GPT-Risk / ORB-Finalizer
OPENAI_API_KEY=your_openai_key
# Claude-Evaluator (deep review, long documents)
ANTHROPIC_API_KEY=your_anthropic_key
# Gemini-VisualVerifier (graphics, screenshots, multimodal confirmation).
# The SAME key also powers image generation AND Veo AI video (Veo needs a PAID Gemini tier —
# pick "Gemini API · pay per request" in Google AI Studio). Optional model override:
# ORB_VIDEO_MODEL=veo-3.0-generate-preview
GEMINI_API_KEY=your_gemini_key

# ── ORB's cloned voice (ElevenLabs) ──────────────────────────
# Clone a voice at elevenlabs.io (Voices → Add → Instant Voice Clone, ~1 min of clean audio),
# copy its Voice ID, and grab your API key. ORB then speaks every answer in that voice.
# ELEVENLABS_API_KEY=your_elevenlabs_key
# ELEVENLABS_VOICE_ID=your_cloned_voice_id
# ELEVENLABS_MODEL=eleven_multilingual_v2

# ── AI video via RunwayML (Gen-4) — preferred video engine when set ───────────
# Runway is image-to-video: ORB paints a first frame with the Gemini key, then Runway animates it.
# RUNWAY_API_KEY=key_xxx
# ORB_VIDEO_PROVIDER=runway          # optional: force "runway" or "veo"

# ── Billing (Stripe) — charge customers per tier ─────────────
# Create a subscription Product+Price per paid plan at dashboard.stripe.com, then paste the
# price IDs below. Webhook: add an endpoint → {PUBLIC_BASE_URL}/api/orb/billing/webhook and
# copy its signing secret into STRIPE_WEBHOOK_SECRET. Without these, billing is simply disabled.
# STRIPE_SECRET_KEY=sk_live_or_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# PUBLIC_BASE_URL=https://ebe-orb.onrender.com
# STRIPE_PRICE_PERSONAL=price_xxx
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_ENTREPRENEUR=price_xxx
# STRIPE_PRICE_EXECUTIVE=price_xxx
# STRIPE_PRICE_ENTERPRISE=price_xxx

# ── Live connectors (OAuth) ──────────────────────────────────
# Google → Gmail + Calendar. Create creds at console.cloud.google.com (OAuth client, Web app)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/orb/oauth/google/callback
# Optional: where to send the user after a successful connect
# OAUTH_SUCCESS_REDIRECT=http://localhost:5173

# ── Senses (time/weather/news) ───────────────────────────────
# Operator location for weather signals (decimal degrees) + label
# DEFAULT_LAT=33.749
# DEFAULT_LON=-84.388
# DEFAULT_CITY=Atlanta, GA
# News: optional NewsAPI key (newsapi.org); without it EBE uses free Hacker News
# NEWS_API_KEY=your_newsapi_key

# ── Reservations (OpenTable) ─────────────────────────────────
# Works today with one-tap booking links (no key). For in-app booking, become an OpenTable
# partner (opentable.com/restaurant-solutions/api-partners, ~3-4 wk approval) and set:
# OPENTABLE_API_TOKEN=your_opentable_partner_token
# OPENTABLE_PARTNER_ID=your_partner_id
# Let EBE email a reservation request straight to the restaurant (true hands-off booking):
# RESEND_API_KEY=your_resend_key
# EBE_FROM_EMAIL=orb@ebehq.com
# Replies (e.g., a restaurant confirming) go here — your real inbox:
# EBE_REPLY_TO=you@gmail.com

# ── Find restaurants "in the area" (Google Maps Platform · Places API) ──
# Separate from the Gemini key and Google sign-in. Enable "Places API (New)" in Google Cloud.
# GOOGLE_PLACES_API_KEY=your_google_maps_platform_key

# Optional per-brain model overrides
# ORB_EXECUTIVE_MODEL=gpt-4.1
# ORB_OPERATIONS_MODEL=gpt-4.1-mini
# ORB_RISK_MODEL=gpt-4.1-mini
# ORB_EVALUATOR_MODEL=claude-opus-4-8
# ORB_VISUAL_MODEL=gemini-2.5-flash
# ORB_FINALIZER_MODEL=gpt-4.1
